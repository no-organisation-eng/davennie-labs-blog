---
interface Props {
  slotId: string;
  minHeight?: number; // px
  format?: 'auto' | 'fluid' | 'rectangle';
}

const { slotId, minHeight = 250, format = 'auto' } = Astro.props;
---

<div class="ad-wrapper-responsive" style={`min-height:${minHeight}px;`}>
  <ins
    class="adsbygoogle"
    style="display:block;width:100%;height:100%;"
    data-ad-client={import.meta.env.PUBLIC_ADSENSE_CLIENT_ID}
    data-ad-slot={slotId}
    data-ad-format={format}
    data-full-width-responsive="true"
  ></ins>
</div>

<script>
  // @ts-ignore
  (window.adsbygoogle = window.adsbygoogle || []).push({});
</script>

<style>
  .ad-wrapper-responsive {
    display: flex;
    justify-content: center;
    align-items: center;
    background: var(--bg-card-color, #161c2d);
    border: 1px dashed rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    overflow: hidden;
    width: 100%;
  }
</style>
