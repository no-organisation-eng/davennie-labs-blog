---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/autorep-nigeria.json';
import EmailCapture from '../components/EmailCapture.astro';

// Opt out of SSG. Run entirely on Cloudflare Edge
export const prerender = false;

const query = Astro.url.searchParams.get('q') || '';

// Try to parse the city from the search query string
let location = data.find(loc => 
  query.toLowerCase().includes(loc.city.toLowerCase()) || 
  query.toLowerCase().includes(loc.displayName.toLowerCase())
);

// Generic fallback if the search doesn't match a known city
if (!location) {
  location = {
    city: 'nigeria',
    displayName: 'Nigeria',
    state: 'Nigeria',
    heroHeadline: 'Turn Facebook Comments into WhatsApp Sales in Nigeria',
    businessCount: '10,000',
    painPoint: 'Stop losing money to slow responses.',
    localContext: 'competitive local markets',
    searchQuery: query || 'Facebook auto reply bot in Nigeria'
  };
}

// Construct SEO metadata
const title = `Search Results: ${query || location.searchQuery} | AutoRep`;
const description = `The ultimate AI lead conversion CRM for businesses searching for "${query || location.searchQuery}". AutoRep acts as your 24/7 sales agent, instantly replying to Facebook comments.`;
---

<BaseLayout title={title} description={description} canonicalOverride={`https://autorep.biz/${location.city}`}>
  <main class="pseo-container">
    <header class="pseo-hero">
      <div class="hero-badge">📍 Optimized for {location.displayName}, {location.state}</div>
      <h1 class="hero-title">{location.heroHeadline}</h1>
      <p class="hero-subtitle">
        AutoRep is like having a 24/7 top-performing sales agent who instantly replies to every Facebook comment, smoothly moves the conversation to WhatsApp, and follows up until the sale is closed. Join over {location.businessCount} forward-thinking brands upgrading their sales pipelines.
      </p>
      <div class="hero-cta">
        <a href="https://autorep.biz" class="btn-primary">Automate Your Comments Now</a>
      </div>
    </header>

    <section class="pseo-content">
      <div class="content-grid">
        <div class="main-content">
          <h2>Why Top Brands in {location.displayName} Choose AutoRep</h2>
          <p>
            {location.painPoint} Customers buy from the business that replies first. From the busy {location.localContext}, smart business owners are transitioning from manual moderation to intelligent AI conversion.
          </p>
          
          <div class="feature-list">
            <div class="feature-item">
              <h3>🧠 Intelligent AI Replies (RAG & Gemini 2.0)</h3>
              <p>AI that actually knows your business. AutoRep reads your uploaded FAQs to give context-accurate, brand-aligned answers—not just generic, frustrating keyword bot responses.</p>
            </div>
            <div class="feature-item">
              <h3>💬 Facebook to WhatsApp Pipeline</h3>
              <p>Move conversations where conversions happen. AutoRep injects smart WhatsApp links directly into Facebook replies to capture the user's phone number instantly.</p>
            </div>
            <div class="feature-item">
              <h3>⏱️ Automated WhatsApp Follow-ups</h3>
              <p>Never let a hot lead go cold. AutoRep triggers automated follow-up sequences (24h, 3d, 7d) that gently nudge the customer toward your final payment or checkout page.</p>
            </div>
          </div>

          <div class="capture-section">
            <EmailCapture />
          </div>
        </div>

        <aside class="sidebar">
          <div class="sidebar-card">
            <h3>Local Market Data</h3>
            <ul class="data-list">
              <li><strong>Target Area:</strong> {location.displayName}</li>
              <li><strong>Region:</strong> {location.state}</li>
              <li><strong>Active Brands:</strong> {location.businessCount}+</li>
              <li><strong>Search Intent:</strong> <em id="page-search-query">"{query || location.searchQuery}"</em></li>
            </ul>
          </div>
          
          <div class="sidebar-card dark">
            <h3>Ready to scale?</h3>
            <p>Don't let manual comment replies cap your revenue.</p>
            <a href="https://autorep.biz" class="btn-secondary intent-cta">Get AutoRep Now</a>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <script define:vars={{ city: location.displayName, query, fallbackQuery: location.searchQuery }}>
    // Rich Intent Capture Script tailored for dynamic searches
    let sessionId = sessionStorage.getItem('autorep_session_id');
    if (!sessionId) {
      sessionId = crypto.randomUUID();
      sessionStorage.setItem('autorep_session_id', sessionId);
    }

    let maxScroll = 0;
    let timeOnPage = 0;
    let ctaClicked = false;
    const finalQuery = query || fallbackQuery;

    // Track Time on Page
    setInterval(() => {
      timeOnPage += 5;
    }, 5000);

    // Track Scroll Depth
    window.addEventListener('scroll', () => {
      const scrollPercent = Math.round((window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100);
      if (scrollPercent > maxScroll) {
        maxScroll = scrollPercent;
      }
    }, { passive: true });

    // Helper to send intent payload
    const sendIntent = (metadata = {}) => {
      navigator.sendBeacon('/api/intent/capture', JSON.stringify({
        sessionId,
        query: finalQuery,
        city,
        sourcePage: window.location.pathname + window.location.search,
        timeOnPage,
        scrollDepth: maxScroll,
        ctaClicked: ctaClicked || metadata.ctaClicked || false,
        metadata
      }));
    };

    // Track CTA Clicks
    document.querySelectorAll('.btn-primary, .btn-secondary, .intent-cta').forEach(btn => {
      btn.addEventListener('click', (e) => {
        ctaClicked = true;
        sendIntent({ event: 'cta_click', targetText: e.target.innerText });
      });
    });

    // Send data when user leaves the page
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') {
        sendIntent({ event: 'page_exit' });
      }
    });
  </script>
</BaseLayout>

<style>
  .pseo-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  .pseo-hero {
    padding: 6rem 0 4rem;
    text-align: center;
    border-bottom: 1px solid var(--border-color);
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(56, 189, 248, 0.1);
    color: var(--accent-color);
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #fff 0%, #9ca3af 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 800px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .btn-primary {
    display: inline-block;
    background: var(--accent-color);
    color: #0f172a;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.125rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(56, 189, 248, 0.3);
    color: #0f172a;
  }

  .btn-secondary {
    display: block;
    text-align: center;
    background: #fff;
    color: #0f172a;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    font-weight: 700;
    margin-top: 1.5rem;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    padding: 4rem 0;
  }

  .main-content h2 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }

  .main-content p {
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin: 3rem 0;
  }

  .feature-item h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .feature-item p {
    font-size: 1rem;
    margin-bottom: 0;
  }

  .sidebar-card {
    background: var(--bg-card-color);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 2rem;
    backdrop-filter: blur(10px);
  }

  .sidebar-card.dark {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  }

  .sidebar-card h3 {
    margin-bottom: 1.5rem;
    font-size: 1.25rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.75rem;
  }

  .data-list {
    list-style: none;
    padding: 0;
  }

  .data-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--text-muted);
  }

  .data-list li strong {
    color: #fff;
  }

  .capture-section {
    margin-top: 4rem;
  }

  @media (max-width: 992px) {
    .content-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero-title {
      font-size: 2.5rem;
    }
  }
</style>
