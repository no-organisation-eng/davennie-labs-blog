---
/**
 * Programmable SEO — Search-to-Slug Bridge
 *
 * Intercepts ?q= queries and dynamically matches them against existing blog
 * posts, rendering the best match with enriched title/description + canonical
 * URL set to the exact search path so Google indexes it.
 */

export const prerender = false;

import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import EmailCapture from '../components/EmailCapture.astro';
import AdSlot from '../components/AdSlot.astro';

// 1. Raw query
const rawQuery = (Astro.url.searchParams.get('q') || '').trim();

// 2. Keyword banks
const LOCATION_KEYWORDS = [
  'lagos', 'abuja', 'kano', 'ibadan', 'port harcourt', 'uyo', 'akwa ibom',
  'enugu', 'benin', 'benin city', 'calabar', 'owerri', 'warri', 'kaduna',
  'ogun', 'oyo', 'delta', 'anambra', 'imo', 'rivers', 'bayelsa', 'cross river',
  'nigeria', 'africa', 'ghana', 'kenya', 'south africa',
];

const NICHE_KEYWORDS = [
  'real estate', 'fintech', 'e-commerce', 'ecommerce', 'healthcare', 'logistics',
  'retail', 'hr', 'human resources', 'crm', 'saas', 'b2b', 'startup', 'freelance',
  'agency', 'consulting', 'education', 'edtech', 'proptech',
];

// 3. Intent extractor
function extractModifiers(query: string): { locations: string[]; niches: string[]; coreTerms: string[] } {
  const lower = query.toLowerCase();
  const locations = LOCATION_KEYWORDS.filter(loc => lower.includes(loc));
  const niches = NICHE_KEYWORDS.filter(n => lower.includes(n));
  let coreRaw = lower;
  [...locations, ...niches].forEach(m => { coreRaw = coreRaw.replace(m, ''); });
  const stopWords = new Set(['for', 'in', 'at', 'the', 'a', 'an', 'and', 'or', 'of', 'to', 'how', 'what', 'best', 'top']);
  const coreTerms = coreRaw.split(/\s+/).map(t => t.trim()).filter(t => t.length > 2 && !stopWords.has(t));
  return { locations, niches, coreTerms };
}

// 4. Scorer
function scorePost(post: any, coreTerms: string[], locations: string[], niches: string[]): number {
  const haystack = [post.data.title, post.data.description, ...(post.data.tags || []), post.data.cluster]
    .join(' ').toLowerCase();
  let score = 0;
  for (const term of coreTerms) { if (haystack.includes(term)) score += 10; }
  for (const niche of niches) { if (haystack.includes(niche)) score += 5; }
  for (const loc of locations) { if (haystack.includes(loc)) score += 3; }
  const clusterMap: Record<string, string[]> = {
    'micro-saas-automation': ['automation', 'pipeline', 'zero-trust', 'agent', 'deploy'],
    'niche-integrations': ['integration', 'api', 'crm', 'webhook', 'connect'],
    'programmatic-asset-building': ['seo', 'programmatic', 'directory', 'adsense', 'pwa'],
  };
  for (const term of (clusterMap[post.data.cluster] || [])) { if (haystack.includes(term)) score += 2; }
  return score;
}

// 5. Fetch + match
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const { locations, niches, coreTerms } = extractModifiers(rawQuery);
const scored = allPosts.map(post => ({ post, score: scorePost(post, coreTerms, locations, niches) })).sort((a, b) => b.score - a.score);
const bestMatch = scored[0]?.score > 0 ? scored[0].post : null;

// 6. Enriched meta
function buildEnrichedMeta(post: any, locations: string[], niches: string[], query: string) {
  const locationStr = locations.map(l => l.charAt(0).toUpperCase() + l.slice(1)).join(' & ');
  const nicheStr = niches.map(n => n.charAt(0).toUpperCase() + n.slice(1)).join(' & ');
  let suffix = '';
  if (nicheStr && locationStr) suffix = ` — ${nicheStr} in ${locationStr}`;
  else if (nicheStr) suffix = ` — ${nicheStr} Edition`;
  else if (locationStr) suffix = ` — ${locationStr} Guide`;
  const enrichedTitle = (post.data.title + suffix).slice(0, 100);
  const queryFormatted = query.replace(/\+/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  const enrichedDesc = `Looking for: "${queryFormatted}". ${post.data.description}`.slice(0, 160);
  return { enrichedTitle, enrichedDesc };
}

const enrichedMeta = bestMatch ? buildEnrichedMeta(bestMatch, locations, niches, rawQuery) : null;

// 7. Render MDX
const renderedContent = bestMatch ? await render(bestMatch) : null;
const MatchedContent = renderedContent?.Content;

// 8. Canonical + meta
const canonicalURL = Astro.url.href;

const formattedDate = bestMatch
  ? new Date(bestMatch.data.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const videoSrc = bestMatch?.data.heroImage?.endsWith('.gif')
  ? bestMatch.data.heroImage.replace('.gif', '.mp4')
  : bestMatch?.data.heroImage?.endsWith('.mp4')
  ? bestMatch.data.heroImage
  : null;

const pageTitle = enrichedMeta
  ? `${enrichedMeta.enrichedTitle} | Davennie Labs`
  : rawQuery
  ? `Search: "${rawQuery}" | Davennie Labs`
  : 'Search | Davennie Labs';

const pageDesc = enrichedMeta?.enrichedDesc || 'Search the Davennie Labs blueprint library for automation and programmatic SEO guides.';
---

<BaseLayout title={pageTitle} description={pageDesc} canonicalOverride={canonicalURL}>

  {bestMatch && enrichedMeta && MatchedContent ? (
    <main class="post-layout-container">

      <div class="reading-progress-container">
        <div class="reading-progress-bar" id="reading-progress"></div>
      </div>

      <div class="intent-banner">
        <span class="intent-label">🎯 Showing best match for</span>
        <span class="intent-query">"{rawQuery.replace(/\+/g, ' ')}"</span>
      </div>

      <article class="article-wrapper">
        <header class="post-header">
          <div class="post-category">{bestMatch.data.cluster.replace(/-/g, ' ')}</div>
          <h1 class="post-title">{enrichedMeta.enrichedTitle}</h1>
          <div class="post-meta">
            <span class="meta-author">David Akpan</span>
            <span class="meta-separator">|</span>
            <time datetime={bestMatch.data.publishDate.toString()}>{formattedDate}</time>
            <span class="meta-separator">|</span>
            <span class="meta-read-time">6 Min Read</span>
          </div>
        </header>

        {bestMatch.data.heroImage && (
          <div class="hero-image-wrapper">
            {videoSrc ? (
              <video autoplay loop muted playsinline class="hero-image" style="width:100%;height:100%;object-fit:cover;">
                <source src={videoSrc} type="video/mp4" />
              </video>
            ) : (
              <img src={bestMatch.data.heroImage} alt={enrichedMeta.enrichedTitle} class="hero-image" />
            )}
          </div>
        )}

        <div class="content-split-grid">
          <div class="article-body">

            {(locations.length > 0 || niches.length > 0) && (
              <div class="context-box">
                <div class="context-box-header">📍 Context Applied to This Blueprint</div>
                <div class="context-box-body">
                  {niches.length > 0 && (
                    <div class="context-item">
                      <span class="context-key">Niche:</span>
                      <span class="context-value">{niches.map(n => n.charAt(0).toUpperCase() + n.slice(1)).join(', ')}</span>
                    </div>
                  )}
                  {locations.length > 0 && (
                    <div class="context-item">
                      <span class="context-key">Market:</span>
                      <span class="context-value">{locations.map(l => l.charAt(0).toUpperCase() + l.slice(1)).join(', ')}</span>
                    </div>
                  )}
                  <p class="context-note">
                    The core blueprint below applies directly to your context. The principles are infrastructure-agnostic — the only variable is who is deploying them.
                  </p>
                </div>
              </div>
            )}

            <MatchedContent />

            <div class="article-ad-container">
              <AdSlot slotId="search-inline-ad" minHeight={250} />
            </div>

            <div class="article-capture-container">
              <EmailCapture />
            </div>

          </div>

          <aside class="sidebar-wrapper">
            <div class="sticky-sidebar">
              <div class="sidebar-widget">
                <h4>Refine Your Search</h4>
                <form action="/search" method="get" class="refine-form">
                  <input type="text" name="q" placeholder="e.g. automation for fintech in lagos" value={rawQuery.replace(/\+/g, ' ')} class="refine-input" />
                  <button type="submit" class="refine-btn">Search Blueprints</button>
                </form>
              </div>

              <div class="sidebar-widget">
                <AdSlot slotId="search-sidebar-ad" minHeight={250} />
              </div>

              <div class="sidebar-widget">
                <RelatedPosts
                  currentSlug={bestMatch.id}
                  tags={bestMatch.data.tags}
                  cluster={bestMatch.data.cluster}
                />
              </div>
            </div>
          </aside>
        </div>
      </article>
    </main>

  ) : (

    <main class="search-fallback-container">
      <div class="search-fallback-header">
        <div class="search-icon">🔍</div>
        {rawQuery ? (
          <h1>No exact match for <em>"{rawQuery.replace(/\+/g, ' ')}"</em></h1>
        ) : (
          <h1>Search Blueprints</h1>
        )}
        <p class="search-fallback-hint">Browse our full library below or try a more specific query.</p>

        <form action="/search" method="get" class="main-search-form">
          <input type="text" name="q" placeholder="e.g. zero trust pipeline in uyo" value={rawQuery.replace(/\+/g, ' ')} class="main-search-input" />
          <button type="submit" class="main-search-btn">Search</button>
        </form>
      </div>

      <div class="fallback-posts-grid">
        {allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()).map(post => (
          <article class="fallback-post-card">
            <div class="fallback-card-meta">
              <span class="fallback-card-cluster">{post.data.cluster.replace(/-/g, ' ')}</span>
              <time datetime={post.data.publishDate.toString()}>
                {new Date(post.data.publishDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
            <h2 class="fallback-card-title"><a href={`/posts/${post.id}/`}>{post.data.title}</a></h2>
            <p class="fallback-card-desc">{post.data.description}</p>
            <div class="fallback-card-tags">
              {post.data.tags.slice(0, 4).map(tag => (
                <a href={`/search?q=${encodeURIComponent(tag)}`} class="tag-chip">#{tag}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </main>

  )}

  <script>
    const progress = document.getElementById('reading-progress');
    if (progress) {
      window.addEventListener('scroll', () => {
        const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
        const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        progress.style.width = ((winScroll / height) * 100) + '%';
      });
    }
  </script>

  <style>
    .post-layout-container,
    .search-fallback-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 3rem 2rem;
      width: 100%;
    }

    .intent-banner {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(56, 189, 248, 0.08);
      border: 1px solid rgba(56, 189, 248, 0.25);
      border-radius: 999px;
      padding: 0.4rem 1.25rem;
      font-size: 0.85rem;
      margin-bottom: 2rem;
    }
    .intent-label { color: var(--text-muted); }
    .intent-query { color: var(--accent-color); font-weight: 700; font-family: var(--font-mono); }

    .reading-progress-container {
      position: fixed; top: 61px; left: 0; width: 100%; height: 3px; background: transparent; z-index: 100;
    }
    .reading-progress-bar {
      height: 100%; background: linear-gradient(90deg, var(--accent-color), #a855f7); width: 0%; transition: width 0.1s ease;
    }

    .article-wrapper { display: flex; flex-direction: column; gap: 2.5rem; }
    .post-header { border-bottom: 1px solid var(--border-color); padding-bottom: 2rem; }
    .post-category { text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.1em; color: var(--accent-color); font-weight: 700; margin-bottom: 0.75rem; }
    .post-title { font-size: 2.75rem; font-weight: 800; line-height: 1.25; margin-bottom: 1rem; letter-spacing: -0.02em; }
    @media (max-width: 768px) { .post-title { font-size: 2rem; } }
    .post-meta { display: flex; gap: 1rem; align-items: center; color: var(--text-muted); font-size: 0.9rem; }
    .meta-separator { color: var(--border-color); }

    .hero-image-wrapper {
      position: relative; width: 100%; aspect-ratio: 16 / 9;
      background: var(--bg-card-color); border: 1px solid var(--border-color); border-radius: 12px; overflow: hidden;
    }
    .hero-image { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; }

    .content-split-grid { display: grid; grid-template-columns: 8fr 4fr; gap: 4rem; }
    @media (max-width: 992px) { .content-split-grid { grid-template-columns: 1fr; gap: 3rem; } }

    .article-body { font-size: 1.125rem; line-height: 1.8; color: #e5e7eb; }
    .article-body :global(p) { margin-bottom: 1.75rem; }
    .article-body :global(h2) { font-size: 1.75rem; margin: 3rem 0 1.5rem; font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }
    .article-body :global(h3) { font-size: 1.4rem; margin: 2.5rem 0 1.25rem; font-weight: 600; }
    .article-body :global(blockquote) { border-left: 4px solid var(--accent-color); background: var(--bg-card-color); padding: 1.5rem 2rem; margin: 2rem 0; border-radius: 0 8px 8px 0; font-style: italic; }
    .article-body :global(ul), .article-body :global(ol) { margin-bottom: 1.75rem; padding-left: 2rem; }
    .article-body :global(li) { margin-bottom: 0.5rem; }
    .article-body :global(strong) { color: #fff; }
    .article-body :global(code) { background: var(--bg-card-color); padding: 0.2rem 0.4rem; border-radius: 4px; font-family: var(--font-mono); font-size: 0.9em; border: 1px solid var(--border-color); }
    .article-body :global(pre code) { background: transparent; padding: 0; border: none; }
    .article-body :global(.visual-wrapper) { margin: 2rem 0; width: 100%; border: 1px solid var(--border-color); border-radius: 8px; overflow: hidden; }
    .article-body :global(.aspect-16-9) { aspect-ratio: 16 / 9; }
    .article-ad-container, .article-capture-container { margin: 3rem 0; }

    .context-box { background: rgba(56, 189, 248, 0.06); border: 1px solid rgba(56, 189, 248, 0.2); border-radius: 12px; margin-bottom: 2rem; overflow: hidden; }
    .context-box-header { background: rgba(56, 189, 248, 0.12); padding: 0.75rem 1.5rem; font-size: 0.85rem; font-weight: 700; font-family: var(--font-mono); color: var(--accent-color); text-transform: uppercase; letter-spacing: 0.05em; }
    .context-box-body { padding: 1.25rem 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
    .context-item { display: flex; gap: 0.75rem; align-items: baseline; font-size: 0.95rem; }
    .context-key { color: var(--text-muted); font-weight: 600; min-width: 60px; }
    .context-value { color: #fff; font-weight: 700; }
    .context-note { color: var(--text-muted); font-size: 0.875rem; line-height: 1.5; margin-top: 0.5rem; font-style: italic; }

    .sticky-sidebar { position: sticky; top: 100px; display: flex; flex-direction: column; gap: 2.5rem; }
    .sidebar-widget { background: var(--bg-card-color); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.5rem; backdrop-filter: blur(8px); }
    .sidebar-widget h4 { font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem; color: var(--text-color); font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem; }
    .refine-form { display: flex; flex-direction: column; gap: 0.75rem; }
    .refine-input { background: rgba(255,255,255,0.05); border: 1px solid var(--border-color); border-radius: 6px; padding: 0.6rem 0.9rem; color: var(--text-color); font-size: 0.9rem; width: 100%; }
    .refine-input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 2px rgba(56,189,248,0.15); }
    .refine-btn { background: var(--accent-color); color: #0b0f19; font-weight: 700; border-radius: 6px; padding: 0.6rem; font-size: 0.9rem; cursor: pointer; transition: background-color 0.2s ease; }
    .refine-btn:hover { background: #7dd3fc; }

    .search-fallback-header { text-align: center; max-width: 680px; margin: 0 auto 4rem; padding-top: 2rem; }
    .search-icon { font-size: 3rem; margin-bottom: 1rem; }
    .search-fallback-header h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 1rem; }
    .search-fallback-header h1 em { color: var(--accent-color); font-style: normal; }
    .search-fallback-hint { color: var(--text-muted); margin-bottom: 2rem; }

    .main-search-form { display: flex; gap: 0.75rem; max-width: 560px; margin: 0 auto; }
    .main-search-input { flex: 1; background: var(--bg-card-color); border: 1px solid var(--border-color); border-radius: 8px; padding: 0.8rem 1.25rem; color: var(--text-color); font-size: 1rem; }
    .main-search-input:focus { outline: none; border-color: var(--accent-color); box-shadow: 0 0 0 3px rgba(56,189,248,0.15); }
    .main-search-btn { background: var(--accent-color); color: #0b0f19; font-weight: 700; border-radius: 8px; padding: 0.8rem 1.5rem; font-size: 1rem; cursor: pointer; white-space: nowrap; transition: background-color 0.2s ease; }
    .main-search-btn:hover { background: #7dd3fc; }

    .fallback-posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 2rem; max-width: 1100px; margin: 0 auto; }
    .fallback-post-card { background: var(--bg-card-color); border: 1px solid var(--border-color); border-radius: 12px; padding: 1.75rem; display: flex; flex-direction: column; gap: 0.75rem; backdrop-filter: blur(8px); transition: transform 0.2s ease, border-color 0.2s ease; }
    .fallback-post-card:hover { transform: translateY(-4px); border-color: rgba(56,189,248,0.3); }
    .fallback-card-meta { display: flex; gap: 1rem; align-items: center; font-size: 0.78rem; font-family: var(--font-mono); color: var(--text-muted); }
    .fallback-card-cluster { color: var(--accent-color); font-weight: 700; text-transform: uppercase; }
    .fallback-card-title { font-size: 1.2rem; font-weight: 700; line-height: 1.35; }
    .fallback-card-title a { color: var(--text-color); }
    .fallback-card-title a:hover { color: var(--accent-color); }
    .fallback-card-desc { color: var(--text-muted); font-size: 0.9rem; line-height: 1.5; }
    .fallback-card-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.25rem; }
    .tag-chip { background: rgba(56,189,248,0.08); border: 1px solid rgba(56,189,248,0.2); color: var(--accent-color); padding: 0.2rem 0.65rem; border-radius: 999px; font-size: 0.78rem; font-family: var(--font-mono); transition: background-color 0.2s ease; }
    .tag-chip:hover { background: rgba(56,189,248,0.15); }

    @media (max-width: 600px) {
      .main-search-form { flex-direction: column; }
      .fallback-posts-grid { grid-template-columns: 1fr; }
    }
  </style>

</BaseLayout>
