---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/autorep-nigeria.json';
import EmailCapture from '../components/EmailCapture.astro';
import { getCollection } from 'astro:content';

// Opt out of SSG. Run entirely on Cloudflare Edge
export const prerender = false;

const query = Astro.url.searchParams.get('q') || '';
const normalizedQuery = query.toLowerCase();

// 1. Parse Blog Posts
const allPosts = await getCollection('posts', ({ data }) => {
  return data.draft !== true;
});

// Filter posts by query
const matchedPosts = allPosts.filter(post => {
  if (!query) return true; // if no query, maybe show all or none. Let's show all recent.
  return post.data.title.toLowerCase().includes(normalizedQuery) || 
         post.data.description.toLowerCase().includes(normalizedQuery) ||
         (post.data.tags && post.data.tags.some(tag => tag.toLowerCase().includes(normalizedQuery)));
});

// Sort by date (newest first)
matchedPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// 2. Intent Detection
// Try to parse the city from the search query string
const locationMatch = data.find(loc => 
  normalizedQuery.includes(loc.city.toLowerCase()) || 
  normalizedQuery.includes(loc.displayName.toLowerCase())
);

// If the query explicitly mentions autorep, or matches a known city, it's a pSEO intent.
const isAutoRepIntent = normalizedQuery.includes('autorep') || !!locationMatch;

let location = locationMatch;
if (isAutoRepIntent && !location) {
  // Generic fallback if it's an AutoRep intent but no specific city matches
  location = {
    city: 'nigeria',
    displayName: 'Nigeria',
    state: 'Nigeria',
    heroHeadline: 'Turn Facebook Comments into WhatsApp Sales in Nigeria',
    businessCount: '10,000',
    painPoint: 'Stop losing money to slow responses.',
    localContext: 'competitive local markets',
    searchQuery: query || 'Facebook auto reply bot in Nigeria'
  };
}

// 3. Construct SEO metadata
let title = '';
let description = '';

if (isAutoRepIntent && location) {
  title = `Search Results: ${query || location.searchQuery} | AutoRep`;
  description = `The ultimate AI lead conversion CRM for businesses searching for "${query || location.searchQuery}".`;
} else {
  title = query ? `Search results for "${query}" | Davennie Labs` : `Search Blog | Davennie Labs`;
  description = `Read our latest articles and blueprints about ${query || 'software engineering and automation'}.`;
}

// Helper to determine which posts to show in the "Related Content" section of the pSEO page
// If there are specific matched posts, show them. Otherwise show the latest 3.
const displayPosts = matchedPosts.length > 0 ? matchedPosts.slice(0, 3) : allPosts.slice(0, 3);
---

<BaseLayout title={title} description={description} canonicalOverride={isAutoRepIntent && location ? `https://autorep.biz/${location.city}` : undefined}>
  
  {isAutoRepIntent && location ? (

    <main class="pseo-container">
      <header class="pseo-hero">
        <div class="hero-badge">📍 Optimized for {location.displayName}, {location.state}</div>
        <h1 class="hero-title">{location.heroHeadline}</h1>
        <p class="hero-subtitle">
          AutoRep is like having a 24/7 top-performing sales agent who instantly replies to every Facebook comment, smoothly moves the conversation to WhatsApp, and follows up until the sale is closed. Join over {location.businessCount} forward-thinking brands upgrading their sales pipelines.
        </p>
        <div class="hero-cta">
          <a href="https://autorep.biz" class="btn-primary">Automate Your Comments Now</a>
        </div>
      </header>

      <section class="pseo-content">
        <div class="content-grid">
          <div class="main-content">
            <h2>Why Top Brands in {location.displayName} Choose AutoRep</h2>
            <p>
              {location.painPoint} Customers buy from the business that replies first. From the busy {location.localContext}, smart business owners are transitioning from manual moderation to intelligent AI conversion.
            </p>
            
            <div class="feature-list">
              <div class="feature-item">
                <h3>🧠 Intelligent AI Replies (RAG & Gemini 2.0)</h3>
                <p>AI that actually knows your business. AutoRep reads your uploaded FAQs to give context-accurate, brand-aligned answers—not just generic, frustrating keyword bot responses.</p>
              </div>
              <div class="feature-item">
                <h3>💬 Facebook to WhatsApp Pipeline</h3>
                <p>Move conversations where conversions happen. AutoRep injects smart WhatsApp links directly into Facebook replies to capture the user's phone number instantly.</p>
              </div>
              <div class="feature-item">
                <h3>⏱️ Automated WhatsApp Follow-ups</h3>
                <p>Never let a hot lead go cold. AutoRep triggers automated follow-up sequences (24h, 3d, 7d) that gently nudge the customer toward your final payment or checkout page.</p>
              </div>
            </div>

            <div class="related-content">
              <h3>📖 Essential Reading for Scale</h3>
              <p>Dive deeper into the operational blueprints related to your search.</p>
              <ul class="related-links">
                {displayPosts.map(post => (
                  <li><a href={`/posts/${post.id}`}>- {post.data.title}</a></li>
                ))}
              </ul>
            </div>

            <div class="capture-section">
              <EmailCapture />
            </div>
          </div>

          <aside class="sidebar">
            <div class="sidebar-card">
              <h3>Local Market Data</h3>
              <ul class="data-list">
                <li><strong>Target Area:</strong> {location.displayName}</li>
                <li><strong>Region:</strong> {location.state}</li>
                <li><strong>Active Brands:</strong> {location.businessCount}+</li>
                <li><strong>Search Intent:</strong> <em id="page-search-query">"{query || location.searchQuery}"</em></li>
              </ul>
            </div>
            
            <div class="sidebar-card dark">
              <h3>Ready to scale?</h3>
              <p>Don't let manual comment replies cap your revenue.</p>
              <a href="https://autorep.biz" class="btn-secondary intent-cta">Get AutoRep Now</a>
            </div>
          </aside>
        </div>
      </section>
    </main>
  ) : (

    <main class="search-results-container">
      <header class="search-header">
        <h1>Search Results</h1>
        <p>Showing insights for: <strong>"{query}"</strong></p>
      </header>

      <div class="results-grid">
        <div class="posts-list">
          {matchedPosts.length > 0 ? (
            matchedPosts.map(post => (
              <article class="post-card">
                <h2><a href={`/posts/${post.id}`}>{post.data.title}</a></h2>
                <p class="post-desc">{post.data.description}</p>
                <div class="post-meta">
                  <span>{new Date(post.data.publishDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  {post.data.tags && post.data.tags.slice(0, 2).map(tag => (
                    <span class="tag">#{tag}</span>
                  ))}
                </div>
              </article>
            ))
          ) : (
            <div class="no-results">
              <h3>No blueprints found for "{query}"</h3>
              <p>Try searching for terms like "automation", "SEO", or "mindset".</p>
            </div>
          )}
        </div>

        <aside class="search-sidebar">
          <div class="sidebar-card dark">
            <h3>Scale Your Operations</h3>
            <p>Automate your sales pipeline with our AI-driven Facebook to WhatsApp CRM.</p>
            <a href="/search?q=autorep+in+nigeria" class="btn-secondary intent-cta">Explore AutoRep</a>
          </div>
        </aside>
      </div>
    </main>
  )}

  <script define:vars={{ city: location?.displayName || 'Global', query, fallbackQuery: location?.searchQuery || 'blog_search' }}>
    // Rich Intent Capture Script tailored for dynamic searches
    let sessionId = sessionStorage.getItem('autorep_session_id');
    if (!sessionId) {
      sessionId = crypto.randomUUID();
      sessionStorage.setItem('autorep_session_id', sessionId);
    }

    let maxScroll = 0;
    let timeOnPage = 0;
    let ctaClicked = false;
    const finalQuery = query || fallbackQuery;

    // Track Time on Page
    setInterval(() => {
      timeOnPage += 5;
    }, 5000);

    // Track Scroll Depth
    window.addEventListener('scroll', () => {
      const scrollPercent = Math.round((window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100);
      if (scrollPercent > maxScroll) {
        maxScroll = scrollPercent;
      }
    }, { passive: true });

    // Helper to send intent payload
    const sendIntent = (metadata = {}) => {
      navigator.sendBeacon('/api/intent/capture', JSON.stringify({
        sessionId,
        query: finalQuery,
        city,
        sourcePage: window.location.pathname + window.location.search,
        timeOnPage,
        scrollDepth: maxScroll,
        ctaClicked: ctaClicked || metadata.ctaClicked || false,
        metadata
      }));
    };

    // Track CTA Clicks
    document.querySelectorAll('.btn-primary, .btn-secondary, .intent-cta').forEach(btn => {
      btn.addEventListener('click', (e) => {
        ctaClicked = true;
        sendIntent({ event: 'cta_click', targetText: e.target.innerText });
      });
    });

    // Send data when user leaves the page
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'hidden') {
        sendIntent({ event: 'page_exit' });
      }
    });
  </script>
</BaseLayout>

<style>
  /* Common PSEO Styles */
  .pseo-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  .pseo-hero { padding: 6rem 0 4rem; text-align: center; border-bottom: 1px solid var(--border-color); }
  .hero-badge { display: inline-block; padding: 0.5rem 1rem; background: rgba(56, 189, 248, 0.1); color: var(--accent-color); border-radius: 9999px; font-size: 0.875rem; font-weight: 600; margin-bottom: 1.5rem; letter-spacing: 0.05em; text-transform: uppercase; }
  .hero-title { font-size: 3.5rem; font-weight: 800; line-height: 1.2; margin-bottom: 1.5rem; background: linear-gradient(135deg, #fff 0%, #9ca3af 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .hero-subtitle { font-size: 1.25rem; color: var(--text-muted); max-width: 800px; margin: 0 auto 2.5rem; line-height: 1.6; }
  .btn-primary { display: inline-block; background: var(--accent-color); color: #0f172a; padding: 1rem 2rem; border-radius: 8px; font-weight: 700; font-size: 1.125rem; transition: transform 0.2s, box-shadow 0.2s; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(56, 189, 248, 0.3); color: #0f172a; }
  .btn-secondary { display: block; text-align: center; background: #fff; color: #0f172a; padding: 0.75rem 1.5rem; border-radius: 6px; font-weight: 700; margin-top: 1.5rem; }
  .content-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 4rem; padding: 4rem 0; }
  .main-content h2 { font-size: 2rem; margin-bottom: 1.5rem; }
  .main-content p { font-size: 1.125rem; color: var(--text-muted); line-height: 1.8; margin-bottom: 2rem; }
  .feature-list { display: flex; flex-direction: column; gap: 2rem; margin: 3rem 0; }
  .feature-item h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }
  .feature-item p { font-size: 1rem; margin-bottom: 0; }
  
  .related-content { margin: 3rem 0; padding: 2rem; background: rgba(56, 189, 248, 0.05); border: 1px solid var(--border-color); border-radius: 12px; }
  .related-content h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }
  .related-content p { font-size: 0.95rem; margin-bottom: 1.5rem; }
  .related-links { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .related-links li a { color: var(--accent-color); font-weight: 600; display: flex; align-items: center; transition: transform 0.2s; }
  .related-links li a:hover { transform: translateX(5px); }

  .sidebar-card { background: var(--bg-card-color); border: 1px solid var(--border-color); border-radius: 12px; padding: 2rem; margin-bottom: 2rem; backdrop-filter: blur(10px); }
  .sidebar-card.dark { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); }
  .sidebar-card h3 { margin-bottom: 1.5rem; font-size: 1.25rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem; }
  .data-list { list-style: none; padding: 0; }
  .data-list li { padding: 0.75rem 0; border-bottom: 1px solid rgba(255, 255, 255, 0.05); color: var(--text-muted); }
  .data-list li strong { color: #fff; }
  .capture-section { margin-top: 4rem; }

  /* Standard Search Results Styles */
  .search-results-container { max-width: 1200px; margin: 0 auto; padding: 4rem 2rem; min-height: 60vh; }
  .search-header { margin-bottom: 3rem; border-bottom: 1px solid var(--border-color); padding-bottom: 2rem; }
  .search-header h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; }
  .search-header p { font-size: 1.1rem; color: var(--text-muted); }
  .results-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 4rem; }
  .posts-list { display: flex; flex-direction: column; gap: 2rem; }
  
  .post-card { background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); padding: 2rem; border-radius: 12px; transition: transform 0.2s, background 0.2s; }
  .post-card:hover { transform: translateY(-3px); background: rgba(255,255,255,0.04); border-color: rgba(56, 189, 248, 0.3); }
  .post-card h2 { font-size: 1.5rem; margin-bottom: 1rem; }
  .post-card h2 a { color: var(--text-color); }
  .post-card h2 a:hover { color: var(--accent-color); text-shadow: none; }
  .post-card .post-desc { color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.6; }
  .post-meta { display: flex; gap: 1rem; font-size: 0.85rem; color: #6b7280; align-items: center; }
  .tag { background: rgba(56, 189, 248, 0.1); color: var(--accent-color); padding: 0.2rem 0.6rem; border-radius: 99px; }
  
  .no-results { padding: 3rem; text-align: center; background: rgba(255,255,255,0.02); border-radius: 12px; border: 1px solid var(--border-color); }
  .no-results h3 { font-size: 1.5rem; margin-bottom: 1rem; }
  .no-results p { color: var(--text-muted); }

  @media (max-width: 992px) {
    .content-grid, .results-grid { grid-template-columns: 1fr; gap: 3rem; }
    .hero-title { font-size: 2.5rem; }
  }
</style>
