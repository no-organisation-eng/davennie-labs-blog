---
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
  heroImage?: string;
  publishDate?: Date;
  cluster?: string;
  tags?: string[];
  canonicalOverride?: string;
}

const { title, description, heroImage, publishDate, cluster, tags, canonicalOverride } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'dark';
      })();
      if (theme === 'light') {
        document.documentElement.classList.add('light-theme');
      } else {
        document.documentElement.classList.remove('light-theme');
      }
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href="/logo-nobg.jpg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Google Fonts: Inter & JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />

    <SEO 
      title={title} 
      description={description} 
      heroImage={heroImage} 
      publishDate={publishDate} 
      cluster={cluster} 
      tags={tags} 
      canonicalOverride={canonicalOverride}
    />

    <style is:global>
      :root {
        --bg-color: #0b0f19;
        --bg-card-color: rgba(22, 28, 45, 0.4);
        --text-color: #f3f4f6;
        --text-muted: #9ca3af;
        --accent-color: #38bdf8;
        --accent-glow: rgba(56, 189, 248, 0.15);
        --border-color: rgba(255, 255, 255, 0.08);
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: var(--font-sans);
        background-color: var(--bg-color);
        color: var(--text-color);
        line-height: 1.6;
        background-image: 
          radial-gradient(at 0% 0%, rgba(56, 189, 248, 0.05) 0px, transparent 50%),
          radial-gradient(at 100% 100%, rgba(56, 189, 248, 0.03) 0px, transparent 50%);
        min-height: 100vh;
        display: flex;
        flex-col: column;
        flex-direction: column;
      }

      a {
        color: var(--accent-color);
        text-decoration: none;
        transition: color 0.2s ease, text-shadow 0.2s ease;
      }

      a:hover {
        color: #7dd3fc;
        text-shadow: 0 0 8px var(--accent-glow);
      }

      /* Premium Tech-Noir Glassmorphism Header */
      header {
        border-bottom: 1px solid var(--border-color);
        background: rgba(11, 15, 25, 0.8);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 50;
      }

      .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-weight: 800;
        font-size: 1.25rem;
        letter-spacing: -0.05em;
        background: linear-gradient(135deg, #fff 0%, var(--accent-color) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .nav-links {
        display: flex;
        gap: 2rem;
      }

      .nav-links a {
        color: var(--text-muted);
        font-weight: 500;
        font-size: 0.95rem;
      }

      .nav-links a:hover, .nav-links a.active {
        color: var(--text-color);
      }

      /* Footer */
      footer {
        margin-top: auto;
        border-top: 1px solid var(--border-color);
        background: rgba(11, 15, 25, 0.95);
        padding: 4rem 2rem 2rem;
      }

      .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 4rem;
      }

      @media (max-width: 768px) {
        .footer-container {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
      }

      .footer-brand h4 {
        margin-bottom: 1rem;
        font-weight: 700;
      }

      .footer-brand p {
        color: var(--text-muted);
        font-size: 0.9rem;
      }

      .footer-links h5 {
        color: var(--text-color);
        margin-bottom: 1.2rem;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.05em;
      }

      .footer-links ul {
        list-style: none;
      }

      .footer-links li {
        margin-bottom: 0.75rem;
      }

      .footer-links a {
        color: var(--text-muted);
        font-size: 0.9rem;
      }

      .footer-links a:hover {
        color: var(--text-color);
      }

      .footer-bottom {
        max-width: 1200px;
        margin: 4rem auto 0;
        padding-top: 2rem;
        border-top: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: var(--text-muted);
        font-size: 0.85rem;
      }

      @media (max-width: 600px) {
        .footer-bottom {
          flex-direction: column;
          gap: 1rem;
          text-align: center;
        }
      }

      /* Code Highlight Custom Styling */
      pre {
        background: #111827 !important;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.25rem;
        margin: 1.5rem 0;
        overflow-x: auto;
        font-family: var(--font-mono);
        font-size: 0.9rem;
      }

      /* PWA Standalone Mode Optimizations */
      .pwa-splash-overlay {
        display: none;
      }
      
      @media (display-mode: standalone) {
        .pwa-splash-overlay {
          position: fixed;
          top: 0;
          left: 0;
          width: 100vw;
          height: 100vh;
          background: #0b0f19;
          display: flex;
          flex-direction: column;
          justify-content: center;
          align-items: center;
          z-index: 9999;
          transition: opacity 0.5s ease, visibility 0.5s ease;
        }
        .splash-logo {
          width: 96px;
          height: 96px;
          border-radius: 12px;
          margin-bottom: 1rem;
          object-fit: cover;
        }
        .splash-text {
          font-family: var(--font-mono);
          font-size: 1rem;
          letter-spacing: 0.1em;
          font-weight: 700;
          color: var(--accent-color);
        }
        
        /* Mobile header & container spacing optimizations */
        header {
          padding-top: 0.5rem;
          padding-bottom: 0.5rem;
        }
        .nav-container {
          padding: 0.5rem 1rem;
        }
      }

      /* Light Theme Override Variables */
      html.light-theme {
        --bg-color: #f9fafb;
        --bg-card-color: #ffffff;
        --text-color: #111827;
        --text-muted: #4b5563;
        --accent-color: #0284c7;
        --accent-glow: rgba(2, 132, 199, 0.1);
        --border-color: rgba(0, 0, 0, 0.08);
      }

      html.light-theme header {
        background: rgba(249, 250, 251, 0.8);
      }

      html.light-theme .logo {
        background: linear-gradient(135deg, #111827 0%, var(--accent-color) 100%);
        -webkit-text-fill-color: transparent;
        -webkit-background-clip: text;
      }

      html.light-theme pre {
        background: #f3f4f6 !important;
        border: 1px solid var(--border-color);
        color: #111827 !important;
      }

      html.light-theme code {
        color: #111827 !important;
      }

      /* Theme Toggle Button Styles */
      .theme-toggle-btn {
        background: none;
        border: 1px solid var(--border-color);
        border-radius: 6px;
        padding: 0.4rem;
        cursor: pointer;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background-color 0.2s, border-color 0.2s;
        color: var(--text-color);
      }
      .theme-toggle-btn:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: var(--accent-color);
      }
      html.light-theme .theme-toggle-btn:hover {
        background: rgba(0, 0, 0, 0.05);
      }

      html.light-theme .sun-icon {
        display: none;
      }
      html:not(.light-theme) .moon-icon {
        display: none;
      }
      
      body {
        transition: background-color 0.3s ease, color 0.3s ease;
      }
    </style>
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(err => {
            console.error('Service Worker registration failed:', err);
          });
        });
      }

      // Capture PWA installation prompt globally
      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        // @ts-ignore
        window.deferredPrompt = e;
      });

      // Handle PWA splash screen dismissal
      window.addEventListener('DOMContentLoaded', () => {
        const splash = document.getElementById('pwa-splash');
        if (splash) {
          setTimeout(() => {
            splash.style.opacity = '0';
            splash.style.visibility = 'hidden';
          }, 800);
        }
      });

      // Handle theme toggle
      const themeToggle = document.getElementById('theme-toggle');
      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const isLight = document.documentElement.classList.toggle('light-theme');
          localStorage.setItem('theme', isLight ? 'light' : 'dark');
        });
      }
    </script>
  </head>
  <body>
    <!-- PWA Loading Splash Screen -->
    <div id="pwa-splash" class="pwa-splash-overlay">
      <img src="/logo-pwa-black.gif" alt="Loading..." class="splash-logo" />
      <div class="splash-text">DAVENNIE LABS</div>
    </div>

    <header>
      <div class="nav-container">
        <a href="/" class="logo">
          <img src="/logo-animated.gif" alt="Logo" style="width: 28px; height: 28px; border-radius: 6px; object-fit: cover;" /> DAVENNIE LABS
        </a>
        <nav class="nav-links">
          <a href="/">Build Guides</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <button id="theme-toggle" class="theme-toggle-btn" aria-label="Toggle theme">
            <span class="sun-icon">☀️</span>
            <span class="moon-icon">🌙</span>
          </button>
        </nav>
      </div>
    </header>

    <slot />

    <footer>
      <div class="footer-container">
        <div class="footer-brand">
          <h4>Davennie Labs</h4>
          <p>Zero-trust architectures, programmatic SEO blueprints, and automated B2B workflows. Built for high-leverage digital asset operations.</p>
        </div>
        <div class="footer-links">
          <h5>Resources</h5>
          <ul>
            <li><a href="/">Blueprints</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h5>Legal</h5>
          <ul>
            <li><a href="/privacy-policy">Privacy Policy</a></li>
            <li><a href="/terms-of-service">Terms of Service</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Davennie Labs. All rights reserved.</p>
        <p>Built with Astro + Cloudflare Pages</p>
      </div>
    </footer>
  </body>
</html>
